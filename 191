-- ===============================
local function convertToHex(idString)
    idString = string.gsub(idString, "^%s*(.-)%s*$", "%1")
    if idString == "" then return "" end
    if string.sub(idString, 1, 2):lower() == "0x" then
        return idString
    end
    local num = tonumber(idString)
    if num then
        return string.format("0x%x", num)
    end
    return idString
end

