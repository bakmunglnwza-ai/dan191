-- ====== HELPERS ======
local function extractIdFromString(str)
	if type(str) ~= "string" then
		return nil
	end
	return str:match("%d+")
end

-- อ่านไอดีเสียงจาก AudioPlayer
-- ตามโครงสร้างจริงในเกม พร็อพเพอร์ตี้ที่เก็บ rbxassetid คือ "Asset"
-- (บางเวอร์ชันอาจใช้ AssetId หรือเป็น Sound object ที่มี SoundId แทน จึงเช็คไว้ทุกแบบ)
local function getAssetIdFromInstance(inst)
	if inst:IsA("Sound") then
		return inst.SoundId
	end

	-- ลองอ่านพร็อพเพอร์ตี้ "Asset" ก่อน (ตรงกับ AudioPlayer ในภาพ Properties)
	local ok1, result1 = pcall(function()
		return inst.Asset
	end)
	if ok1 and result1 and result1 ~= "" then
		return result1
	end

	-- เผื่อบางอันใช้ AssetId แทน
	local ok2, result2 = pcall(function()
		return inst.AssetId
	end)
	if ok2 and result2 and result2 ~= "" then
		return result2
	end

	return nil
end

-- ====== BUILD AUDIO ROWS ======
local function createAudioRow(folder, layoutOrder)
	-- ตรวจสอบว่ามี AudioPlayer หรือไม่
	local audioPlayer = folder:FindFirstChild("AudioPlayer")
	if not audioPlayer then
		return nil
	end

	-- หา ID เพลงก่อน เพื่อเช็ค blacklist
	local idText = "ไม่พบ ID"
	local assetId = getAssetIdFromInstance(audioPlayer)
	if assetId then
		idText = extractIdFromString(assetId) or tostring(assetId)
	end

	-- ข้ามถ้าไอดีอยู่ใน blacklist
	if BLACKLISTED_IDS[idText] then
		return nil
	end

	local row = Instance.new("Frame")
	row.Name = folder.Name
	row.Size = UDim2.new(1, 0, 0, 60)
	row.BackgroundColor3 = ROW_COLOR
	row.BackgroundTransparency = 1
	row.LayoutOrder = layoutOrder
	row.Parent = scrollFrame
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	-- อนิเมชั่น slide-in + fade-in ของแต่ละ row
	local delayTime = (layoutOrder - 1) * 0.05
	delay(delayTime, function()
		if not row or not row.Parent then return end
		row.Position = UDim2.new(0.08, 0, 0, 0)
		TweenService:Create(row, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0,
			Position = UDim2.new(0, 0, 0, 0),
		}):Play()
	end)

	-- รูปเพลง (ฝั่งซ้าย)
	local icon = Instance.new("ImageLabel")
	icon.Size = UDim2.fromOffset(46, 46)
	icon.Position = UDim2.new(0, 7, 0.5, 0)
	icon.AnchorPoint = Vector2.new(0, 0.5)
	icon.BackgroundColor3 = Color3.fromRGB(50, 50, 56)
	icon.Image = "rbxassetid://4483345875"
	icon.ScaleType = Enum.ScaleType.Fit
	icon.Parent = row
	Instance.new("UICorner", icon).CornerRadius = UDim.new(0, 6)

	-- ชื่อ/ID เพลง (กลาง) -- โชว์ไอดีของ AudioPlayer แทนชื่อโฟลเดอร์
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size = UDim2.new(1, -140, 1, 0)
	nameLabel.Position = UDim2.new(0, 62, 0, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = idText
	nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextSize = 14
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
	nameLabel.Parent = row

	-- ปุ่มก๊อป ID (ฝั่งขวา)
	local copyButton = Instance.new("TextButton")
	copyButton.Size = UDim2.fromOffset(64, 30)
	copyButton.Position = UDim2.new(1, -71, 0.5, 0)
	copyButton.AnchorPoint = Vector2.new(0, 0.5)
	copyButton.BackgroundColor3 = ACCENT_COLOR
	copyButton.Text = "ก๊อป"
	copyButton.Font = Enum.Font.GothamBold
	copyButton.TextSize = 14
	copyButton.TextColor3 = Color3.fromRGB(255, 255, 255)
	copyButton.Parent = row
	Instance.new("UICorner", copyButton).CornerRadius = UDim.new(0, 6)

	copyButton.MouseEnter:Connect(function()
		TweenService:Create(copyButton, TweenInfo.new(0.12), {
			BackgroundColor3 = ACCENT_HOVER_COLOR,
			Size = UDim2.fromOffset(68, 32),
		}):Play()
	end)
	copyButton.MouseLeave:Connect(function()
		TweenService:Create(copyButton, TweenInfo.new(0.12), {
			BackgroundColor3 = ACCENT_COLOR,
			Size = UDim2.fromOffset(64, 30),
		}):Play()
	end)

	copyButton.MouseButton1Click:Connect(function()
		-- ลองคัดลอกเข้าคลิปบอร์ดอัตโนมัติก่อน (ใช้ได้เฉพาะบางตัวรันสคริปต์ที่รองรับ setclipboard)
		if type(setclipboard) == "function" then
			local ok = pcall(setclipboard, idText)
			if ok then
				local originalText = copyButton.Text
				copyButton.Text = "คัดลอกแล้ว"
				delay(1, function()
					if copyButton and copyButton.Parent then
						copyButton.Text = originalText
					end
				end)
				return
			end
		end

		-- ถ้าคัดลอกอัตโนมัติไม่ได้ (Roblox ปกติ) ให้เปิดกล่องที่เลือกข้อความให้พร้อม Ctrl+C
		openCopyPopup(idText)
	end)

	return row
end

local function populateAudioList()
	for _, child in ipairs(scrollFrame:GetChildren()) do
		if child:IsA("Frame") then
			child:Destroy()
		end
	end

	local folder = ReplicatedStorage
	for _, name in ipairs(AUDIO_FOLDER_PATH) do
		folder = folder and folder:FindFirstChild(name)
		if not folder then
			break
		end
	end

	if not folder then
		warn("[MusicListGui] ไม่พบโฟลเดอร์เสียงตามพาธที่กำหนด (แก้ AUDIO_FOLDER_PATH ในสคริปต์)")
		return
	end

	local order = 0
	for _, item in ipairs(folder:GetChildren()) do
		if item:IsA("Folder") then
			order = order + 1
			createAudioRow(item, order)
		end
	end
end

populateAudioList()

-- ====== ANIMATION HELPERS ======
local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local tweenInfoClose = TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.In)

local isOpen = false

local function openFrame()
	isOpen = true
	toggleButton.Visible = false -- ปุ่มเปิด/ปิดจะหายไปตอนเปิด UI

	mainFrame.Visible = true
	mainFrame.Size = UDim2.fromOffset(280, 280)
	mainFrame.BackgroundTransparency = 1
	local tween = TweenService:Create(mainFrame, tweenInfo, {
		Size = UDim2.fromOffset(320, 320),
		BackgroundTransparency = 0,
	})
	tween:Play()
	-- Fade in children
	for _, child in ipairs(mainFrame:GetDescendants()) do
		if child:IsA("Frame") or child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("ScrollingFrame") then
			child.Visible = true
		end
	end
end

local function closeFrame()
	isOpen = false

	local tween = TweenService:Create(mainFrame, tweenInfoClose, {
		Size = UDim2.fromOffset(280, 280),
		BackgroundTransparency = 1,
	})
	tween:Play()
	tween.Completed:Connect(function()
		mainFrame.Visible = false
		mainFrame.Size = UDim2.fromOffset(320, 320)
		mainFrame.BackgroundTransparency = 0
		toggleButton.Visible = true -- ปุ่มเปิด/ปิดกลับมาอยู่ตำแหน่งเดิม
	end)
end

